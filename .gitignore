# Database (보안: 인증 토큰, 세션 데이터 포함)
*.db
*.db.bak
*.db-wal
*.db-shm

# Python
__pycache__/
*.py[cod]
*.egg-info/
build/

# IDE
.vscode/
.idea/
*.swp
*.swo

# Desktop (Electron) — node_modules만 제외, dist는 LFS로 관리
desktop/node_modules/
desktop/*/node_modules/

# Playwright MCP (테스트 캐시/비디오)
.playwright-mcp/

# OS
.DS_Store
Thumbs.db

# Screenshots (루트 디렉토리)
/*.png

# C# / .NET
desktop/server-manager-csharp/*/bin/
desktop/server-manager-csharp/*/obj/
*.user
*.suo
*.nupkg

# Secrets / Auth
.env
*.pem
*.key
credentials.json

# Build artifacts (open-source 공개 시 제외)
release/
desktop/*/dist/
desktop/*/win-unpacked/
flutter_app/build/
*.AppImage
*.exe
*.blockmap
flutter_app/android/key.properties
flutter_app/android/fastlane/

# Claude Code 로컬/임시 파일
.claude/settings.local.json
.claude/.active_ticket

# Play Store 서비스계정 키 — 절대 커밋 금지
**/service-account.json
**/play-store/
*.keystore
flutter_app/android/key.properties

# 로컬 DB 백업 (tar로 이동 — git 커밋 제외)
local_backup/
